resource "aws_cloudwatch_metric_alarm" "devops-alarm" {
  alarm_name                = "devops-alarm"
  comparison_operator       = "GreaterThanThreshold"
  evaluation_periods        = 1
  metric_name               = "CPUUtilization"
  period                    = 300
  statistic                 = "Average"
  threshold                 = 80
}
